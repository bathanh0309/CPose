                    <mxGeometry x="220" y="40" width="80" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="leg_text" value="Thresholds:&#10;• Strong Match: ≥ 0.65&#10;• Weak Match: &lt; 0.40&#10;• Confirm Frames: 15" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#000000;" parent="legend_box" vertex="1">

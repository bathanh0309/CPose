                </mxCell>
                <mxCell id="edge_p7" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontColor=#000000;labelBackgroundColor=none;strokeColor=#000000;" parent="posture_container" source="post_vert_check" target="post_standing" edge="1">
                    <mxGeometry x="0.0261" y="14" relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="118" y="353"/>
                            <mxPoint x="179" y="353"/>
                        </Array>
                        <mxPoint as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="voting_container" value="5.3 Temporal Voting Mechanism" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=14;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1060" width="540" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="vote_data" value="Data Structure:&#10;votes = {&#10;  track_id: {&#10;    global_id: count&#10;  }&#10;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;align=left;spacingLeft=10;fontFamily=Courier New;fontColor=#000000;" parent="voting_container" vertex="1">
                    <mxGeometry x="40" y="50" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="vote_logic" value="Logic:&#10;1. vote(track_id, global_id)&#10;   → votes[track_id][global_id] += 1&#10;&#10;2. is_confirmed(track_id, global_id)&#10;   → votes ≥ CONFIRM_FRAMES (15)&#10;&#10;3. get_best(track_id)&#10;   → argmax(votes[track_id])" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;align=left;spacingLeft=10;fontColor=#000000;" parent="voting_container" vertex="1">
                    <mxGeometry x="260" y="50" width="260" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="vote_purpose" value="Purpose: Prevent ID flicker&#10;• Require N consecutive frames&#10;• Reject single-frame false positives&#10;• Smooth ID transitions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontColor=#000000;" parent="voting_container" vertex="1">
                    <mxGeometry x="40" y="170" width="480" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="hungarian_container" value="5.4 Hungarian Assignment (Multi-Person Matching)" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="620" y="1332" width="540" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="hung_cost" value="Build Cost Matrix:&#10;cost[i][j] = 1 - similarity(det_i, gallery_j)&#10;&#10;Size: (N_detections × N_gallery)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;spacingLeft=10;fontColor=#000000;" parent="hungarian_container" vertex="1">
                    <mxGeometry x="40" y="50" width="240" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="hung_algo" value="Hungarian Algorithm:&#10;row_ind, col_ind = &#10;  linear_sum_assignment(cost)&#10;&#10;Complexity: O(n³)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;spacingLeft=10;fontFamily=Courier New;fontColor=#000000;" parent="hungarian_container" vertex="1">
                    <mxGeometry x="300" y="50" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="hung_assign" value="Assignment Logic:&#10;• If cost[i][j] &lt; 0.35: Assign det_i → gallery_j&#10;• Else if Master camera: Create new ID&#10;• Else (Slave): Assign UNK" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontColor=#000000;" parent="hungarian_container" vertex="1">
                    <mxGeometry x="40" y="150" width="480" height="100" as="geometry"/>
                </mxCell>

# ================================
# HAVEN Camera Configuration
# ================================

# Local-only camera sources are stored in resources.txt, which must stay out of git.
# Keep this file free of real IPs, usernames, passwords, or full RTSP URLs.
CAMERA_NAME=local_camera
CAMERA_IP=CHANGE_ME
CAMERA_PORT=554
CAMERA_USER=CHANGE_ME
CAMERA_PASSWORD=CHANGE_ME

# RTSP Streams
RTSP_STREAM_HD=stream1
RTSP_STREAM_SD=stream2
DEFAULT_STREAM=SD

# AI Model Configuration
# ----------------------
# Chọn model phù hợp với phần cứng:
#   - backend/models/yolo11n-pose.pt: Nhanh, nhẹ (Jetson Nano, Edge devices)
#   - backend/models/yolo11s-pose.pt: Chính xác hơn (Laptop CPU i5/i7)
AI_MODEL_PATH=backend/models/yolo11n-pose.pt
AI_CONF_THRES=0.25
AI_IOU_THRES=0.45
AI_IMG_SIZE=640
AI_MAX_DET=10
AI_SKIP_FRAMES=3

# ROI Mode (Region of Interest - focus on bed area)
# Set ROI_ENABLED=True to only detect in specified region
# Coordinates are percentages of frame (0.0-1.0)
ROI_ENABLED=False
ROI_X1=0.5
ROI_Y1=0.0
ROI_X2=1.0
ROI_Y2=0.7

# Inference Stream (HD recommended for better detection of distant objects)
AI_USE_HD_STREAM=False

# Debug Overlay (show conf, fps, detections on frame)
AI_DEBUG_OVERLAY=True

# Performance Tuning
FRAME_BUFFER_SIZE=1
RECONNECT_BACKOFF_SECONDS=5
MAX_RECONNECT_ATTEMPTS=10
STREAM_TIMEOUT_SECONDS=30
FPS_LIMIT=15
JPEG_QUALITY=80
RESIZE_WIDTH=0

# Advanced Options
DEBUG_MODE=False
WS_PING_INTERVAL=30

# Roboflow Inference
INFERENCE_URL=http://localhost:9001
INFERENCE_EVERY_N=3

    <diagram name="CV Knowledge Pipeline" id="cv-knowledge">
        <mxGraphModel dx="875" dy="458" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="3500" background="#ffffff" math="0" shadow="0">
            <root>
                <mxCell id="0"/>

                <mxCell id="leg_decision" value="Decision Point" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#000000;" parent="legend_box" vertex="1">
                    <mxGeometry x="20" y="40" width="80" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="leg_process" value="Process" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;" parent="legend_box" vertex="1">
                    <mxGeometry x="120" y="40" width="80" height="50" as="geometry"/>

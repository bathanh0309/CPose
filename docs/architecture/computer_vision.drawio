                <mxCell id="header-main" value="🎓 COMPUTER VISION LEARNING &amp; WORK PIPELINE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=36;fontStyle=1;fontColor=#1a237e;" parent="1" vertex="1">
                    <mxGeometry x="100" y="20" width="2700" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="header-sub" value="Lộ trình học tập và làm việc thực tế tại NeuralTrans - From Learning to Production" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontColor=#424242;" parent="1" vertex="1">
                    <mxGeometry x="100" y="85" width="2700" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="work-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=4;" parent="1" vertex="1">
                    <mxGeometry x="100" y="150" width="850" height="400" as="geometry"/>
                </mxCell>
                <mxCell id="work-title" value="🏢 MÔ HÌNH LÀM VIỆC TẠI NEURALTRANS" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#0D47A1;" parent="1" vertex="1">
                    <mxGeometry x="100" y="160" width="850" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="agile" value="&lt;b&gt;⚡ Agile/Scrum Workflow&lt;/b&gt;&lt;br&gt;• Sprint 1-2 tuần&lt;br&gt;• Mục tiêu rõ ràng mỗi sprint&lt;br&gt;• Review &amp; feedback nhanh&lt;br&gt;• Họp cập nhật tiến độ định kỳ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=10;fontSize=12;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="130" y="220" width="380" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="git" value="&lt;b&gt;📦 Git/GitHub Workflow&lt;/b&gt;&lt;br&gt;• Quản lý mã nguồn&lt;br&gt;• Pull Request &amp; Code Review&lt;br&gt;• Merge vào nhánh chính&lt;br&gt;• Reproducibility ưu tiên" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;align=left;spacingLeft=10;fontSize=12;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="540" y="220" width="380" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="tools-table" value="&lt;b&gt;🛠️ CÔNG CỤ &amp; MỤC ĐÍCH&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Git/GitHub:&lt;/b&gt; Lưu trữ code, PR, review&lt;br&gt;&lt;b&gt;VS Code/Jupyter:&lt;/b&gt; Dev, experiment, logging&lt;br&gt;&lt;b&gt;OpenCV/FFmpeg:&lt;/b&gt; Xử lý ảnh/video, RTSP&lt;br&gt;&lt;b&gt;PyTorch/Ultralytics:&lt;/b&gt; Train &amp; inference&lt;br&gt;&lt;b&gt;FastAPI:&lt;/b&gt; REST/WebSocket API&lt;br&gt;&lt;b&gt;Docker:&lt;/b&gt; Chuẩn hóa môi trường" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#3F51B5;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="130" y="360" width="790" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="workflow-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=4;" parent="1" vertex="1">
                    <mxGeometry x="1127" y="149" width="595" height="420" as="geometry"/>
                </mxCell>
                <mxCell id="workflow-title" value="🔄 QUY TRÌNH LÀM VIỆC KỸ SƯ COMPUTER VISION" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#4A148C;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="160" width="850" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="step1" value="&lt;b&gt;1️⃣ Nhận yêu cầu &amp; Phân tích&lt;/b&gt;&lt;br&gt;Input/Output, Realtime, Target device&lt;br&gt;Metrics: Precision/Recall/mAP, FPS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=2;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1168" y="220" width="242" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="step2" value="&lt;b&gt;2️⃣ Thu thập &amp; Khảo sát dữ liệu&lt;/b&gt;&lt;br&gt;Phân bố lớp, chất lượng ảnh&lt;br&gt;Điều kiện ánh sáng, góc nhìn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=2;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1440" y="220" width="241" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="step3" value="&lt;b&gt;3️⃣ Gán nhãn &amp; Chuẩn hóa&lt;/b&gt;&lt;br&gt;Format annotation, cấu trúc thư mục&lt;br&gt;Quality check, versioning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=2;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1437" y="313" width="245" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="step4" value="&lt;b&gt;4️⃣ Dataloader &amp; Augmentation&lt;/b&gt;&lt;br&gt;Resize/Normalize, Augmentation&lt;br&gt;Phù hợp với dữ liệu thực tế" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=2;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1163" y="313" width="247" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="step5" value="&lt;b&gt;5️⃣ Lựa chọn Model &amp; Thiết kế&lt;/b&gt;&lt;br&gt;Trade-off: Accuracy - Speed - Deploy&lt;br&gt;Baseline experiment setup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=2;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1164" y="400" width="244" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="step6" value="&lt;b&gt;6️⃣ Huấn luyện &amp; Tinh chỉnh&lt;/b&gt;&lt;br&gt;Theo dõi loss/metric&lt;br&gt;Hyperparameter tuning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=2;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1440" y="400" width="241" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="step7" value="&lt;b&gt;7️⃣ Đánh giá &amp; Error Analysis&lt;/b&gt;&lt;br&gt;Phân tích lỗi, thu thập hard samples&lt;br&gt;Validation trên test set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=2;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1440" y="492" width="242" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="step8" value="&lt;b&gt;8️⃣ Tối ưu &amp; Triển khai&lt;/b&gt;&lt;br&gt;Export, Quantization&lt;br&gt;Tích hợp API, Logging, Demo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#81C784;strokeColor=#2E7D32;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1169" y="492" width="241" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="internship" value="&lt;b&gt;🎯 NỘI DUNG THỰC TẬP&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Giai đoạn 1 - ISIC 2018:&lt;/b&gt; Phân loại ảnh da&lt;br&gt;Pipeline training, đánh giá, repo minh chứng&lt;br&gt;&lt;br&gt;&lt;b&gt;Giai đoạn 2 - HAVEN:&lt;/b&gt; Multi-camera ReID&lt;br&gt;Detection/Tracking realtime, Edge deployment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF59D;strokeColor=#F9A825;strokeWidth=3;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="580" width="790" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="knowledge-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#F57C00;strokeWidth=4;" parent="1" vertex="1">
                    <mxGeometry x="1900" y="150" width="950" height="650" as="geometry"/>
                </mxCell>
                <mxCell id="knowledge-title" value="📚 KIẾN THỨC &amp; KỸ NĂNG CẦN CÓ" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#E65100;" parent="1" vertex="1">
                    <mxGeometry x="1900" y="160" width="950" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="foundation" value="&lt;b&gt;🧮 Kiến thức nền tảng&lt;/b&gt;&lt;br&gt;• Toán: Xác suất, thống kê, gradient&lt;br&gt;• DSA: Xử lý dữ liệu, tối ưu&lt;br&gt;• Xử lý ảnh: Convolution, transforms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1930" y="220" width="420" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="software" value="&lt;b&gt;💻 Kỹ năng phần mềm&lt;/b&gt;&lt;br&gt;• PyTorch, Ultralytics (YOLO)&lt;br&gt;• OpenCV, Pillow, Albumentations&lt;br&gt;• VS Code, Jupyter, Git/GitHub&lt;br&gt;• FastAPI/Flask cho API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="2380" y="220" width="440" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="system" value="&lt;b&gt;⚙️ Kỹ năng hệ thống (Edge AI)&lt;/b&gt;&lt;br&gt;• Linux: cài môi trường, SSH, service&lt;br&gt;• Network: RTSP, HTTP/WebSocket&lt;br&gt;• Ràng buộc phần cứng: GPU/RAM&lt;br&gt;• Chiến lược tối ưu realtime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1930" y="330" width="420" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="soft" value="&lt;b&gt;🤝 Kỹ năng mềm&lt;/b&gt;&lt;br&gt;• Giao tiếp, báo cáo rõ ràng&lt;br&gt;• Tiếp nhận feedback &amp; cải tiến&lt;br&gt;• Tự học, đọc paper&lt;br&gt;• Làm việc nhóm, kỷ luật" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="2380" y="330" width="440" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="arch-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=4;" parent="1" vertex="1">
                    <mxGeometry x="203" y="590" width="649" height="344" as="geometry"/>
                </mxCell>
                <mxCell id="arch-title" value="🏗️ KIẾN TRÚC 4 LỚP - NEURALTRANS TECH STACK" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#1B5E20;" parent="1" vertex="1">
                    <mxGeometry x="100" y="600" width="850" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="layer1" value="&lt;b&gt;L1: DATA LAYER (Tầng Dữ liệu)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Thu thập: Camera CCTV/RTSP, Dataset công khai&lt;br&gt;• Lưu trữ: Raw data + Processed data&lt;br&gt;• Quản lý: Kiểm tra chất lượng, gán nhãn&lt;br&gt;• Versioning: Data versioning, tracking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="226" y="653" width="292" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="layer2" value="&lt;b&gt;L2: PROCESSING LAYER (Tầng Xử lý)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Training Pipeline: Trên GPU workstation&lt;br&gt;• Inference Pipeline: Server/Edge deployment&lt;br&gt;• Pre/Post Processing: Resize, NMS, Tracking&lt;br&gt;• Optimization: Tối ưu tốc độ, memory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="556" y="653" width="265" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="layer3" value="&lt;b&gt;L3: APPLICATION LAYER (Tầng Ứng dụng)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• API Services: REST/WebSocket&lt;br&gt;• Business Logic: Cảnh báo, thống kê, phát hiện&lt;br&gt;• Dashboard: Giám sát vận hành realtime&lt;br&gt;• Integration: Frontend, mobile app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="556" y="795" width="264" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="layer4" value="&lt;b&gt;L4: DEPLOYMENT &amp; OPERATIONS (Tầng Triển khai)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Environment: Docker/Conda chuẩn hóa&lt;br&gt;• Service Management: Config, logging, monitoring&lt;br&gt;• Deployment: Self-hosted, on-premise, edge&lt;br&gt;• Maintainability: Tái lập, bền vững" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="228" y="795" width="290" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="arch-principle" value="&lt;b&gt;💡 NGUYÊN TẮC THIẾT KẾ&lt;/b&gt;&lt;br&gt;&lt;br&gt;✅ &lt;b&gt;Tách biệt trách nhiệm:&lt;/b&gt; Thay model không vỡ API&lt;br&gt;✅ &lt;b&gt;Modular:&lt;/b&gt; Tái sử dụng giữa các dự án&lt;br&gt;✅ &lt;b&gt;Scalable:&lt;/b&gt; Mở rộng dễ dàng theo yêu cầu&lt;br&gt;✅ &lt;b&gt;Flexible:&lt;/b&gt; Server, on-premise, edge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEDC8;strokeColor=#558B2F;strokeWidth=3;align=left;spacingLeft=10;fontSize=11;fontStyle=0;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="130" y="1220" width="790" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="curriculum-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0277BD;strokeWidth=4;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="850" width="1850" height="440" as="geometry"/>
                </mxCell>
                <mxCell id="curriculum-title" value="🎓 LIÊN HỆ VỚI CHƯƠNG TRÌNH ĐÀO TẠO KHOA ĐIỆN TỬ - VIỄN THÔNG" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#01579B;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="860" width="1850" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="courses" value="&lt;b&gt;📖 CÁC HỌC PHẦN LIÊN QUAN&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Lập trình - Thuật toán:&lt;/b&gt;&lt;br&gt;C/C++, Python, DSA&lt;br&gt;&lt;br&gt;&lt;b&gt;Hệ thống - Máy tính:&lt;/b&gt;&lt;br&gt;Kiến trúc máy tính, HĐH, Mạng&lt;br&gt;&lt;br&gt;&lt;b&gt;Điện tử - Nhúng:&lt;/b&gt;&lt;br&gt;Vi xử lý, Hệ thống nhúng&lt;br&gt;&lt;br&gt;&lt;b&gt;Xử lý tín hiệu/ảnh:&lt;/b&gt;&lt;br&gt;Xử lý tín hiệu số, Ảnh số" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B3E5FC;strokeColor=#0277BD;strokeWidth=2;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="920" width="420" height="350" as="geometry"/>
                </mxCell>
                <mxCell id="bridge" value="&lt;b&gt;🌉 KHOẢNG TRỐNG CẦN BỔ SUNG&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;MLOps/Deployment:&lt;/b&gt;&lt;br&gt;Đóng gói, versioning model, API&lt;br&gt;&lt;br&gt;&lt;b&gt;Realtime Video:&lt;/b&gt;&lt;br&gt;RTSP ingest, buffer, drop frame&lt;br&gt;&lt;br&gt;&lt;b&gt;Dữ liệu thực tế:&lt;/b&gt;&lt;br&gt;Xử lý nhiễu, ánh sáng, rung&lt;br&gt;&lt;br&gt;&lt;b&gt;Báo cáo kỹ thuật:&lt;/b&gt;&lt;br&gt;Tài liệu reproducible" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#F57C00;strokeWidth=3;align=left;spacingLeft=10;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1480" y="920" width="420" height="350" as="geometry"/>
                </mxCell>
                <mxCell id="industry" value="&lt;b&gt;🏭 YÊU CẦU THỰC TẾ NGÀNH&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Production-Ready:&lt;/b&gt;&lt;br&gt;Không chỉ accuracy cao&lt;br&gt;Mà phải chạy ổn định thực tế&lt;br&gt;&lt;br&gt;&lt;b&gt;System Integration:&lt;/b&gt;&lt;br&gt;Camera, thiết bị, network&lt;br&gt;&lt;br&gt;&lt;b&gt;Edge Deployment:&lt;/b&gt;&lt;br&gt;Tối ưu cho edge device&lt;br&gt;&lt;br&gt;&lt;b&gt;Maintainability:&lt;/b&gt;&lt;br&gt;Code clean, tài liệu đầy đủ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=3;align=left;spacingLeft=10;fontSize=11;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="1930" y="920" width="420" height="350" as="geometry"/>
                </mxCell>
                <mxCell id="path" value="&lt;b&gt;🎯 LỘ TRÌNH HỌC TẬP&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Nền tảng:&lt;/b&gt; Học phần ĐH&lt;br&gt;↓&lt;br&gt;&lt;b&gt;Thực hành:&lt;/b&gt; Project cá nhân&lt;br&gt;↓&lt;br&gt;&lt;b&gt;Thực tập:&lt;/b&gt; ISIC + HAVEN&lt;br&gt;↓&lt;br&gt;&lt;b&gt;Triển khai:&lt;/b&gt; Production&lt;br&gt;↓&lt;br&gt;&lt;b&gt;Chuyên sâu:&lt;/b&gt; Research" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;strokeWidth=3;align=center;fontSize=11;fontStyle=1;fontColor=#000000;" parent="1" vertex="1">
